{
  "manifest_version": 3,
  "name": "GEML Viewer",
  "version": "0.1.0",
  "description": "Render .geml and .gemlhistory documents in the browser, with build-time reference checking shown as diagnostics.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["file:///*", "*://*/*"],
      "include_globs": ["*.geml*"],
      "js": ["dist/viewer.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/fonts/*"],
      "matches": ["file:///*", "*://*/*"]
    }
  ]
}
